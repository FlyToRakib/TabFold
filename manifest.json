{
  "manifest_version": 3,
  "name": "TabFold",
  "version": "1.0.0",
  "description": "Powerful, one-click tab management. Organize, export, and suspend tabs to save memory and focus.",
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "alarms",
    "scripting",
    "clipboardWrite"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open TabFold"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
      },
      "description": "Open TabFold popup"
    },
    "export-markdown": {
      "suggested_key": {
        "default": "Ctrl+Shift+M",
        "mac": "Command+Shift+M"
      },
      "description": "Quickly export active window tabs to Markdown"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}