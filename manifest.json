{
  "manifest_version": 3,
  "name": "TabFold - Smart Tab Manager",
  "short_name": "TabFold",
  "version": "1.0.1",
  "description": "Powerful tab manager. Organize, group, auto-suspend to save memory, and export URLs in one click. Boost focus and productivity.",
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "alarms",
    "scripting",
    "clipboardWrite"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open TabFold"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+F"
      },
      "description": "Open TabFold popup"
    }
  },
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}